rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Wiki uploads: authenticated users can write to their own folder, anyone can read
    match /wiki/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Task uploads: authenticated users can write to their own folder, anyone can read
    match /tasks/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
