rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function existingOwner() {
      return isOwner(resource.data.uid);
    }

    function incomingOwner() {
      return isOwner(request.resource.data.uid);
    }

    function keepsSameOwner() {
      return resource.data.uid == request.resource.data.uid;
    }

    function hasOnlyKeys(allowed) {
      return request.resource.data.keys().hasOnly(allowed);
    }

    function isTimestampOrNull(value) {
      return value == null || value is timestamp;
    }

    function isStringOrNull(value) {
      return value == null || value is string;
    }

    function isBoolOrNull(value) {
      return value == null || value is bool;
    }

    function isNumberOrNull(value) {
      return value == null || value is int || value is float;
    }

    function validOnboardingStatus(value) {
      return value is string && value in ['pending', 'completed', 'skipped'];
    }

    function validOnboardingProgress(value) {
      return value is map &&
        value.keys().hasOnly(['taskCreate', 'taskDetails', 'taskManage', 'taskViews', 'projects', 'notesCreate', 'notesManage', 'wiki']) &&
        value.keys().hasAll(['taskCreate', 'taskDetails', 'taskManage', 'taskViews', 'projects', 'notesCreate', 'notesManage', 'wiki']) &&
        validOnboardingStatus(value.taskCreate) &&
        validOnboardingStatus(value.taskDetails) &&
        validOnboardingStatus(value.taskManage) &&
        validOnboardingStatus(value.taskViews) &&
        validOnboardingStatus(value.projects) &&
        validOnboardingStatus(value.notesCreate) &&
        validOnboardingStatus(value.notesManage) &&
        validOnboardingStatus(value.wiki);
    }

    function validOnboardingCurrentStep(value) {
      return value == null || (value is string && value in ['taskCreate', 'taskDetails', 'taskManage', 'taskViews', 'projects', 'notesCreate', 'notesManage', 'wiki']);
    }

    function validTodo() {
      return hasOnlyKeys([
        'uid', 'text', 'memo', 'dueDate', 'priority', 'projectId',
        'imageUrl', 'completed', 'archived', 'createdAt', 'orderIndex',
        'dueTime', 'calendarReminderMinutes', 'calendarReminderMinutesList',
        'syncCalendar', 'calendarEventId',
        'source', 'sourceItemId', 'sourceUrl', 'courseTitle', 'ddayText', 'syncedAt',
        'remindersSent',
        'remindersSent'
      ]) &&
      request.resource.data.text is string &&
      request.resource.data.text.size() > 0 &&
      isStringOrNull(request.resource.data.memo) &&
      isStringOrNull(request.resource.data.dueDate) &&
      (!request.resource.data.keys().hasAny(['dueTime']) || isStringOrNull(request.resource.data.dueTime)) &&
      isStringOrNull(request.resource.data.projectId) &&
      isStringOrNull(request.resource.data.imageUrl) &&
      (!request.resource.data.keys().hasAny(['calendarEventId']) || isStringOrNull(request.resource.data.calendarEventId)) &&
      (!request.resource.data.keys().hasAny(['calendarReminderMinutes']) || isNumberOrNull(request.resource.data.calendarReminderMinutes)) &&
      (!request.resource.data.keys().hasAny(['calendarReminderMinutesList']) ||
        (request.resource.data.calendarReminderMinutesList is list &&
         request.resource.data.calendarReminderMinutesList.size() <= 8)) &&
      (!request.resource.data.keys().hasAny(['syncCalendar']) || isBoolOrNull(request.resource.data.syncCalendar)) &&
      (!request.resource.data.keys().hasAny(['source']) || isStringOrNull(request.resource.data.source)) &&
      (!request.resource.data.keys().hasAny(['sourceItemId']) || isStringOrNull(request.resource.data.sourceItemId)) &&
      (!request.resource.data.keys().hasAny(['sourceUrl']) || isStringOrNull(request.resource.data.sourceUrl)) &&
      (!request.resource.data.keys().hasAny(['courseTitle']) || isStringOrNull(request.resource.data.courseTitle)) &&
      (!request.resource.data.keys().hasAny(['ddayText']) || isStringOrNull(request.resource.data.ddayText)) &&
      (!request.resource.data.keys().hasAny(['syncedAt']) || isTimestampOrNull(request.resource.data.syncedAt)) &&
      request.resource.data.priority is string &&
      request.resource.data.priority in ['low', 'medium', 'high'] &&
      request.resource.data.completed is bool &&
      request.resource.data.archived is bool &&
      isTimestampOrNull(request.resource.data.createdAt) &&
      isNumberOrNull(request.resource.data.orderIndex);
    }

    function validNote() {
      return hasOnlyKeys([
        'uid', 'text', 'color', 'x', 'y', 'archived', 'createdAt'
      ]) &&
      request.resource.data.text is string &&
      request.resource.data.text.size() > 0 &&
      request.resource.data.color is string &&
      request.resource.data.color in ['yellow', 'blue', 'green', 'pink', 'purple', 'orange'] &&
      isNumberOrNull(request.resource.data.x) &&
      isNumberOrNull(request.resource.data.y) &&
      isBoolOrNull(request.resource.data.archived) &&
      isTimestampOrNull(request.resource.data.createdAt);
    }

    function validProject() {
      return hasOnlyKeys([
        'uid', 'name', 'color', 'createdAt'
      ]) &&
      request.resource.data.name is string &&
      request.resource.data.name.size() > 0 &&
      request.resource.data.color is string &&
      request.resource.data.color.size() > 0 &&
      isTimestampOrNull(request.resource.data.createdAt);
    }

    function validBookmark() {
      return hasOnlyKeys([
        'uid', 'url', 'title', 'tags', 'createdAt'
      ]) &&
      request.resource.data.url is string &&
      request.resource.data.url.size() > 0 &&
      isStringOrNull(request.resource.data.title) &&
      (request.resource.data.tags is list) &&
      isTimestampOrNull(request.resource.data.createdAt);
    }

    function validWikiPage() {
      return hasOnlyKeys([
        'uid', 'title', 'parentId', 'projectId', 'content', 'createdAt', 'updatedAt',
        'icon', 'coverUrl', 'coverPosition', 'coverPositionX', 'coverHeight', 'coverZoom', 'coverCropMode',
        'ogTried'
      ]) &&
      request.resource.data.title is string &&
      request.resource.data.title.size() > 0 &&
      isStringOrNull(request.resource.data.parentId) &&
      (!request.resource.data.keys().hasAny(['projectId']) || isStringOrNull(request.resource.data.projectId)) &&
      (!request.resource.data.keys().hasAny(['icon']) || isStringOrNull(request.resource.data.icon)) &&
      (!request.resource.data.keys().hasAny(['coverUrl']) || isStringOrNull(request.resource.data.coverUrl)) &&
      (!request.resource.data.keys().hasAny(['coverPosition']) || isNumberOrNull(request.resource.data.coverPosition)) &&
      (!request.resource.data.keys().hasAny(['coverPositionX']) || isNumberOrNull(request.resource.data.coverPositionX)) &&
      (!request.resource.data.keys().hasAny(['coverHeight']) || isNumberOrNull(request.resource.data.coverHeight)) &&
      (!request.resource.data.keys().hasAny(['coverZoom']) || isNumberOrNull(request.resource.data.coverZoom)) &&
      (!request.resource.data.keys().hasAny(['coverCropMode']) || isStringOrNull(request.resource.data.coverCropMode)) &&
      (!request.resource.data.keys().hasAny(['ogTried']) || isBoolOrNull(request.resource.data.ogTried)) &&
      request.resource.data.content is map &&
      isTimestampOrNull(request.resource.data.createdAt) &&
      isTimestampOrNull(request.resource.data.updatedAt);
    }

    match /todos/{todoId} {
      allow read, delete: if existingOwner();
      allow create: if incomingOwner() && validTodo();
      allow update: if existingOwner() && incomingOwner() && keepsSameOwner() && validTodo();
    }

    match /notes/{noteId} {
      allow read, delete: if existingOwner();
      allow create: if incomingOwner() && validNote();
      allow update: if existingOwner() && incomingOwner() && keepsSameOwner() && validNote();
    }

    match /projects/{projectId} {
      allow read, delete: if existingOwner();
      allow create: if incomingOwner() && validProject();
      allow update: if existingOwner() && incomingOwner() && keepsSameOwner() && validProject();
    }

    match /bookmarks/{bookmarkId} {
      allow read, delete: if existingOwner();
      allow create: if incomingOwner() && validBookmark();
      allow update: if existingOwner() && incomingOwner() && keepsSameOwner() && validBookmark();
    }

    match /wiki_pages/{pageId} {
      allow read, delete: if existingOwner();
      allow create: if incomingOwner() && validWikiPage();
      allow update: if existingOwner() && incomingOwner() && keepsSameOwner() && validWikiPage();
    }

    match /eclass_items/{itemId} {
      allow read: if existingOwner();
      allow delete: if false;
      allow create, update: if false;
    }

    match /eclass_connections/{connectionId} {
      allow read: if isOwner(connectionId);
      allow write: if false;
    }

    match /eclass_syllabi/{docId} {
      allow read: if existingOwner();
      allow create, update, delete: if false;
    }

    match /fcm_tokens/{tokenId} {
      allow read: if existingOwner();
      allow create: if incomingOwner() &&
        hasOnlyKeys(['uid', 'token', 'platform', 'userAgent', 'createdAt', 'lastSeenAt']) &&
        request.resource.data.token is string &&
        request.resource.data.token.size() > 0 &&
        isStringOrNull(request.resource.data.platform) &&
        isStringOrNull(request.resource.data.userAgent) &&
        isTimestampOrNull(request.resource.data.createdAt) &&
        isTimestampOrNull(request.resource.data.lastSeenAt);
      allow update: if existingOwner() && incomingOwner() && keepsSameOwner() &&
        hasOnlyKeys(['uid', 'token', 'platform', 'userAgent', 'createdAt', 'lastSeenAt']) &&
        request.resource.data.token is string &&
        request.resource.data.token.size() > 0;
      allow delete: if existingOwner();
    }

    match /fcm_tokens/{tokenId} {
      allow read: if existingOwner();
      allow create: if incomingOwner() &&
        hasOnlyKeys(['uid', 'token', 'platform', 'userAgent', 'createdAt', 'lastSeenAt']) &&
        request.resource.data.token is string &&
        request.resource.data.token.size() > 0 &&
        isStringOrNull(request.resource.data.platform) &&
        isStringOrNull(request.resource.data.userAgent) &&
        isTimestampOrNull(request.resource.data.createdAt) &&
        isTimestampOrNull(request.resource.data.lastSeenAt);
      allow update: if existingOwner() && incomingOwner() && keepsSameOwner() &&
        hasOnlyKeys(['uid', 'token', 'platform', 'userAgent', 'createdAt', 'lastSeenAt']) &&
        request.resource.data.token is string &&
        request.resource.data.token.size() > 0;
      allow delete: if existingOwner();
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) &&
        request.resource.data.uid == userId &&
        hasOnlyKeys([
          'uid', 'email', 'displayName', 'onboardingCompleted',
          'onboardingCompletedAt', 'onboardingProgress', 'onboardingCurrentStep',
          'createdAt', 'updatedAt'
        ]) &&
        isStringOrNull(request.resource.data.email) &&
        isStringOrNull(request.resource.data.displayName) &&
        request.resource.data.onboardingCompleted is bool &&
        isTimestampOrNull(request.resource.data.onboardingCompletedAt) &&
        validOnboardingProgress(request.resource.data.onboardingProgress) &&
        validOnboardingCurrentStep(request.resource.data.onboardingCurrentStep) &&
        isTimestampOrNull(request.resource.data.createdAt) &&
        isTimestampOrNull(request.resource.data.updatedAt);
      allow delete: if isOwner(userId);
    }
  }
}
